# =============================================================================
# Air-Gapped Docker Compose Environment
# =============================================================================
# Copy to .env before running the air-gapped compose stack.
# This file lives in airgapped/docker-compose/ alongside the compose files.
# =============================================================================

# --- App Store ---
# Generate: env LC_CTYPE=C tr -dc "a-zA-Z0-9_-" < /dev/urandom | head -c 64; echo
SECRET_KEY=CHANGE_THIS_IN_AIRGAP_USE_64_CHAR_RANDOM_STRING

DB_PASSWORD=changeme_airgap_password

ALLOWED_HOSTS=localhost,127.0.0.1,appstore.local
APPSTORE_DOMAIN=appstore.local

# --- Optional managed test Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me
NEXTCLOUD_TRUSTED_DOMAINS=localhost nextcloud-test
