# =============================================================================
# Nextcloud App Store Deployment Toolkit — Environment Variables
# =============================================================================
# Copy to .env and fill in values before running any scripts.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Build Settings
# -----------------------------------------------------------------------------
APPSTORE_VERSION=master
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# App Store Domain & URLs
# -----------------------------------------------------------------------------
APPSTORE_DOMAIN=appstore.local
FILESERVER_DOMAIN=files.local

# URL that Nextcloud uses to query the local App Store API
APPSTORE_API_URL=https://appstore.local/api/v1

# Base URL where mirrored app archives are served
FILE_SERVER_URL=https://files.local/apps

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
CONTAINER_RUNTIME=docker

# Kubernetes namespace for App Store deployment
K8S_NAMESPACE=nextcloud-appstore

# Optional: kubectl context to use (leave blank for current context)
KUBECTL_CONTEXT=

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_PASSWORD=changeme_staging_password
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=nextcloudappstore
DATABASE_USER=nextcloudappstore

# -----------------------------------------------------------------------------
# Django Security Settings
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a unique secret key for production!
# Use: env LC_CTYPE=C tr -dc "a-zA-Z0-9_-" < /dev/urandom | head -c 64; echo
# NOTE: Avoid $ characters — docker-compose interprets them as variables
SECRET_KEY=K9xmR2vL7pNqW4jF8tY1cB5hA3sD6gE0iUzXwV_oMkJnHbQrTyPaCfGlZeI2uOx3

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,appstore.local

# Set to True only for local debugging (never in production)
DEBUG=False

# -----------------------------------------------------------------------------
# Initial Setup Flags (set to true on first run only)
# -----------------------------------------------------------------------------
LOAD_FIXTURES=false
IMPORT_TRANSLATIONS=false

# -----------------------------------------------------------------------------
# Admin User (optional — created automatically on first run if set)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Site Domain (for social login and email links)
# -----------------------------------------------------------------------------
SITE_DOMAIN=appstore.local

# -----------------------------------------------------------------------------
# GitHub OAuth (for social login — not used in air-gapped environments)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# -----------------------------------------------------------------------------
# GitHub API Token (required for syncing Nextcloud releases from GitHub)
# -----------------------------------------------------------------------------
GITHUB_API_TOKEN=ghp_your_github_personal_access_token

# -----------------------------------------------------------------------------
# Nextcloud Mode
# -----------------------------------------------------------------------------
# external : Nextcloud is already deployed elsewhere — only configure it
# managed  : Deploy a temporary Nextcloud instance for testing
NEXTCLOUD_MODE=external

# How the existing Nextcloud is deployed:
# compose | k8s | ssh | manual
NEXTCLOUD_RUNTIME=compose

# -----------------------------------------------------------------------------
# Existing Docker Compose Nextcloud
# Used by: airgapped/scripts/configure-nextcloud-compose.sh
# -----------------------------------------------------------------------------
NEXTCLOUD_COMPOSE_PROJECT_DIR=/opt/nextcloud
NEXTCLOUD_COMPOSE_FILE=docker-compose.yml
NEXTCLOUD_CONTAINER_NAME=nextcloud

# -----------------------------------------------------------------------------
# Existing Kubernetes Nextcloud
# Used by: airgapped/scripts/configure-nextcloud-k8s.sh
# -----------------------------------------------------------------------------
NEXTCLOUD_K8S_NAMESPACE=nextcloud
NEXTCLOUD_K8S_POD_SELECTOR=app=nextcloud
NEXTCLOUD_K8S_CONTAINER=nextcloud

# -----------------------------------------------------------------------------
# Existing SSH / Bare-Metal Nextcloud
# Used by: airgapped/scripts/configure-nextcloud-ssh.sh
# -----------------------------------------------------------------------------
NEXTCLOUD_SSH_HOST=
NEXTCLOUD_SSH_USER=
NEXTCLOUD_PATH=/var/www/html

# -----------------------------------------------------------------------------
# Optional Managed Test Nextcloud
# Applies only when NEXTCLOUD_MODE=managed or using online up managed-nextcloud
# -----------------------------------------------------------------------------
DEPLOY_MANAGED_NEXTCLOUD=false
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me
NEXTCLOUD_TRUSTED_DOMAINS=localhost,nextcloud,nextcloud.local

# -----------------------------------------------------------------------------
# Packaging (air-gapped package build)
# -----------------------------------------------------------------------------
# Include nextcloud:stable-apache image in the package?
# Set true only if you need a managed test Nextcloud in the air-gapped env
INCLUDE_MANAGED_NEXTCLOUD_IMAGES=false

AIRGAP_PACKAGE_DIR=airgapped
AIRGAP_IMAGE_DIR=airgapped/images
AIRGAP_EXPORT_DIR=airgapped/exports

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
DEFAULT_FROM_EMAIL=appstore@example.com
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# -----------------------------------------------------------------------------
# reCAPTCHA (optional)
# -----------------------------------------------------------------------------
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Discourse Integration (optional)
# -----------------------------------------------------------------------------
DISCOURSE_URL=https://help.nextcloud.com
DISCOURSE_USER=
DISCOURSE_TOKEN=

# -----------------------------------------------------------------------------
# SSL/HTTPS
# -----------------------------------------------------------------------------
USE_HTTPS=True

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_ANON=100/hour
THROTTLE_USER=1000/hour
THROTTLE_APP_UPLOAD=100/day
THROTTLE_APP_REGISTER=100/day
