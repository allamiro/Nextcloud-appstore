# =============================================================================
# Nextcloud App Store Deployment - Git Ignore
# =============================================================================

# Exports directory (large files, generated)
exports/
*.tar
*.tar.gz

# Environment files with secrets
.env
.env.local
.env.production

# SSL certificates
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.pem
!nginx/ssl/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/

# Logs
*.log
logs/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Kubernetes secrets with actual values
k8s/secrets-production.yaml

# Air-gapped package artifacts (large generated files)
airgapped/images/*.tar.gz
airgapped/images/*.tar.gz.sha256
airgapped/exports/*.sql.gz
airgapped/exports/*.sql.gz.sha256
airgapped/exports/app-archives/files/
nextcloud-appstore-airgap-*.tar.gz
